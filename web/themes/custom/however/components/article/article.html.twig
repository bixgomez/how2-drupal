<article class="article">
	{% set person_bio_content = person_bio|render %}
	{% set rendered_body_sections = [] %}
	{% for item in content_body_sections %}
		{% if item['#paragraph'] is defined %}
			{% set paragraph = item['#paragraph'] %}
			{% set section_title_display = paragraph.field_title_display.value|default('') %}
			{% set section_title = paragraph.field_title.value|default('') %}
			{% set section_link_title = section_title_display
				? section_title_display|replace({'<p>': '', '</p>': ''})
				: section_title %}
			{% set rendered_body_sections = rendered_body_sections|merge([{
				paragraph: paragraph,
				anchor: 'section-' ~ (rendered_body_sections|length + 1),
				link_title: section_link_title
			}]) %}
		{% endif %}
	{% endfor %}
	<div class="content">

		{% if not hide_title %}
				{% if title_display|render|trim %}
					<div class="content-section content-section--lg">
						<h1>{{ title_display }}</h1>
					</div>
				{% elseif title %}
					<div class="content-section content-section--lg">
						<h1>{{ title }}</h1>
					</div>
				{% endif %}
		{% endif %}
		
		<div class="content-section content-section--sm">
			{% include "@issue-meta/issue-meta.html.twig" with {
				journal_name: journal,
				journal_url: journal_url,
				volume_issue: volume_issue,
				issue_pub_date: issue_pub_date,
				issue_url: issue_url,
				archive_url: archive_url[0]['#url'].toString(),
				person_bio_link: "#bios",
				section_links: section_links,
			} %}	
		</div>
		
		{# <div class="content-section content-section--sm">
			<h2 class="dev-heading">This is an article (not a section)</h2>
		</div> #}

		{# 
		{% if section_links %}
			{% set section_link = section_links|first %}
			<a href="{{ section_link.url }}" class="back-to-section">
				← Back to {{ section_link.title }}
			</a>
		{% endif %}
		#}

		{# 
		{% if person_bio.0['#paragraph'].field_person.entity.title.value %}
			<div class="content-section content-section--lg">
					<p class="author-name">{{ person_bio.0['#paragraph'].field_person.entity.title.value }}</p>
			</div>
		{% endif %}
		#}

		{% if person_bio_content|striptags|trim %}
			<div id="bios" class="content-section content-section--lg">
				{{ person_bio_content|raw }}
			</div>
		{% endif %}

		{% if working_notes['#items'] and not working_notes['#items'].isEmpty %}
			<div class="content-section content-section--lg">
				<h3>Working Notes</h3>
				{{ working_notes }}
			</div>
		{% endif %}

		{% if content.body[0]['#text'] %}
			<div class="content-section content-section--lg">
				{{ body }}
			</div>
		{% endif %}

		{% if rendered_body_sections|length > 1 %}
			<div class="content-section content-section--lg">
				<ul class="body-section-links">
					{% for section in rendered_body_sections %}
						<li>
							<a href="#{{ section.anchor }}">{{ section.link_title|raw }}</a>
						</li>
					{% endfor %}
				</ul>
			</div>
		{% endif %}

		{% for section in rendered_body_sections %}
			<div id="{{ section.anchor }}" class="content-section content-section--lg">
				{{ drupal_entity('paragraph', section.paragraph.id.value) }}
			</div>
		{% endfor %}

		{% if images['#items'] and not images['#items'].isEmpty %}
			<div class="content-section content-section--lg">
				<h2>Article Images</h2>
				<p>
					Click on an image to open a full-screen version.
				</p>
				{{ images }}
			</div>
		{% endif %}

	</div>
</article>
